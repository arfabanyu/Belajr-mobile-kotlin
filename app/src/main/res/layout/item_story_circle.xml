<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:padding="4dp">

    <!-- Avatar melingkar tanpa container kotak -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivStoryAvatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/default_profile"
        app:shapeAppearanceOverlay="@style/CircleImageView" />

    <!-- Online Status Dot di pojok bawah kanan -->
    <View
        android:id="@+id/viewOnlineStatus"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_online_dot"
        android:elevation="4dp" />

    <!-- Hidden ID untuk mencegah crash di Adapter -->
    <TextView
        android:id="@+id/tvStoryName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</FrameLayout>
