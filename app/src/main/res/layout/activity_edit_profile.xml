<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F3F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Banner + Avatar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <!-- Banner background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@color/primaryblue" />

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Back" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="20dp"
                android:text="Edit Profile"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Save Button top-right -->
            <TextView
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@android:color/transparent"
                android:text="Save"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:padding="4dp" />

            <!-- Avatar container -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="0dp">

                <!-- Avatar image -->
                <ImageView
                    android:id="@+id/imgProfilePicture"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ppplaceholder"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_white_border"
                    android:clipToOutline="true" />

                <!-- Camera badge -->
                <ImageView
                    android:id="@+id/btnChangePhoto"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_camera"
                    android:background="@color/primaryblue"
                    android:padding="5dp"
                    android:elevation="2dp" />
            </FrameLayout>
        </FrameLayout>

        <!-- Username below avatar -->
        <TextView
            android:id="@+id/tvUsernameDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="2dp"
            android:text="@string/placeholder_username"
            android:textColor="#060607"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvEmailDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/placeholder_email"
            android:textColor="#72767D"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <!-- ─── SECTION: USER INFORMATION ─── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USER INFORMATION"
            android:textColor="#72767D"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp"
            android:paddingTop="4dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Display Name -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DISPLAY NAME"
                    android:textColor="#72767D"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:paddingTop="8dp"
                    android:paddingBottom="2dp"/>

                <EditText
                    android:id="@+id/etDisplayName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/placeholder_username"
                    android:textColor="#060607"
                    android:textColorHint="#BABEC4"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:paddingStart="0dp"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EBEDEF"/>

                <!-- Username -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="USERNAME"
                    android:textColor="#72767D"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:paddingTop="12dp"
                    android:paddingBottom="2dp"/>

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/placeholder_username_at"
                    android:textColor="#060607"
                    android:textColorHint="#BABEC4"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:paddingStart="0dp"
                    android:inputType="textNoSuggestions"
                    android:imeOptions="actionNext"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EBEDEF"/>

                <!-- Phone -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PHONE NUMBER"
                    android:textColor="#72767D"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:paddingTop="12dp"
                    android:paddingBottom="2dp"/>

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/placeholder_phone"
                    android:textColor="#060607"
                    android:textColorHint="#BABEC4"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:paddingStart="0dp"
                    android:inputType="phone"
                    android:imeOptions="actionNext"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EBEDEF"/>

                <!-- Email -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textColor="#72767D"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:paddingTop="12dp"
                    android:paddingBottom="2dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/placeholder_email"
                    android:textColor="#060607"
                    android:textColorHint="#BABEC4"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:paddingStart="0dp"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionDone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── SECTION: ABOUT ME ─── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ABOUT ME"
            android:textColor="#72767D"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:hint="@string/placeholder_bio"
                android:textColor="#060607"
                android:textColorHint="#BABEC4"
                android:textSize="14sp"
                android:padding="16dp"
                android:background="@android:color/transparent"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top"
                android:maxLines="6"/>
        </androidx.cardview.widget.CardView>

        <!-- Bottom spacing -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp"/>

    </LinearLayout>
</ScrollView>